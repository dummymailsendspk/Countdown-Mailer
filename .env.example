# .env.example
# Copy this file to .env and fill in your real values.
# Never commit your actual .env file to version control.

# ── Email ──────────────────────────────────────────────────────────────────────
# The Gmail address that will send the emails.
SENDER_EMAIL=

# A Gmail App Password (not your regular Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=

# The address that will receive the daily countdown emails.
RECIPIENT_EMAIL=

# ── Countdown ──────────────────────────────────────────────────────────────────
# The target date in YYYY-MM-DD format.
# Emails stop (gracefully) once this date has passed.
TARGET_DATE=

# ── AI ─────────────────────────────────────────────────────────────────────────
# Your Google Gemini API key.
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# ── Timezone ───────────────────────────────────────────────────────────────────
# IANA timezone string used by node-cron so midnight fires at the right moment.
# Examples: America/New_York | Europe/London | Asia/Kolkata | UTC
TIMEZONE=